; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited.

config_version=5

[application]

config/name="Football 2.0"
config/description="Sensible Soccer inspired game with expansion features"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4")

[display]

window/size/viewport_width=336
window/size/viewport_height=272
window/size/window_width_override=1344
window/size/window_height_override=1088
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[layer_names]

2d_physics/layer_1="pitch_boundary"
2d_physics/layer_2="ball"
2d_physics/layer_3="players"
2d_physics/layer_4="goals"
2d_physics/layer_5="boundaries"
2d_physics/layer_6="tackle_hitbox"
2d_physics/layer_7="pickup_zone"

[physics]

common/physics_ticks_per_second=50

[input]

move_up={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194320,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
